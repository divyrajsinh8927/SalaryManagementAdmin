<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the requested file or directory exists physically, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Otherwise, cleanly forward the request to your root index.php file
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>